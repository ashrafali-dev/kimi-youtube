# .env.example - Railway Environment Variables
# Copy this to Railway Variables section

# ===== REQUIRED =====
PORT=3000
BASE_URL=https://your-app.up.railway.app

# ===== YOUTUBE API =====
YT_CLIENT_ID=your_youtube_oauth_client_id.apps.googleusercontent.com
YT_CLIENT_SECRET=your_youtube_oauth_client_secret
YT_ACCESS_TOKEN=  # Auto-filled after OAuth

# ===== GOOGLE DRIVE =====
DRIVE_CLIENT_ID=your_drive_client_id.apps.googleusercontent.com
DRIVE_CLIENT_SECRET=your_drive_client_secret
DRIVE_ACCESS_TOKEN=  # Auto-filled after OAuth

# ===== AI SERVICES (at least one required) =====
GEMINI_API_KEY=AIzaSy...   # Google AI Studio থেকে নিন
GROK_API_KEY=xai-...       # x.ai থেকে নিন
OPENAI_API_KEY=sk-...      # OpenAI থেকে নিন
